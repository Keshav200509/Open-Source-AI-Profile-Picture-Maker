# -----------------------------------------------------------------------
# Backend
# -----------------------------------------------------------------------
PORT=4000

# Leave blank to run in mock mode (copies the image + 1s delay).
# Set to the actual container URL when running with Docker Compose.
REMBG_API_URL=http://rembg:7000
GFPGAN_API_URL=http://gfpgan:8000
STABLE_DIFFUSION_URL=http://stable-diffusion:7860

# Cleanup interval in milliseconds (default: 1 hour)
CLEANUP_INTERVAL_MS=3600000

# Maximum upload file size in MB
MAX_FILE_SIZE_MB=10

# -----------------------------------------------------------------------
# Frontend (Vite)
# -----------------------------------------------------------------------
# Set this when the frontend is served from a different origin than the backend.
# Leave blank when using the Vite dev server proxy (localhost).
VITE_API_BASE_URL=
