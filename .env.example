# -----------------------------------------------------------------------
# Backend
# -----------------------------------------------------------------------
PORT=4000

# ── Tier 1: Replicate cloud AI (recommended — no GPU required) ──────────────
# Get a free API token at https://replicate.com
# When set, uses: rembg (background removal), GFPGAN (face restoration),
# Stable Diffusion img2img (style transfer).
REPLICATE_API_TOKEN=

# ── Tier 2: Self-hosted AI containers (requires GPU server) ─────────────────
# Leave blank when not running Docker Compose AI services.
REMBG_API_URL=
GFPGAN_API_URL=
STABLE_DIFFUSION_URL=

# ── Tier 3 (automatic fallback) ─────────────────────────────────────────────
# When no token/URL is set, sharp-based image processing runs automatically:
# face enhance = sharpen + normalize + saturation boost
# style presets = colour grading (tint, saturation, brightness per style)

# Cleanup interval in milliseconds (default: 1 hour)
CLEANUP_INTERVAL_MS=3600000

# Maximum upload file size in MB
MAX_FILE_SIZE_MB=10

# -----------------------------------------------------------------------
# Frontend (Vite)
# -----------------------------------------------------------------------
# Set this when the frontend is served from a different origin than the backend.
# Leave blank when using the Vite dev server proxy (localhost).
VITE_API_BASE_URL=
